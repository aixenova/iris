{
  "manifest_version": 3,
  "name": "Prescription Submit Capture",
  "version": "1.0.0",
  "description": "Stores submit values from the page and shows the latest captured payload.",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "View Saved Submit Data",
    "default_popup": "popup.html"
  }
}
